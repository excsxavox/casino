PORT=3001

# demo | nowpayments
CRYPTO_PROVIDER=nowpayments

# NOWPayments — https://account.nowpayments.io
NOWPAYMENTS_API_KEY=tu_api_key
NOWPAYMENTS_IPN_SECRET=tu_ipn_secret

# true = sandbox (api-sandbox.nowpayments.io)
NOWPAYMENTS_SANDBOX=true

# URL pública HTTPS de tu API (requerida para webhooks IPN)
# Ejemplo con ngrok: https://abc123.ngrok-free.app
PUBLIC_API_URL=https://tu-dominio.com

# Solo modo demo
# CRYPTO_PROVIDER=demo
# CRYPTO_DEMO_CONFIRM_MS=12000
